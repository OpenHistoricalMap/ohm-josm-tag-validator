  <node id='9000052' visible='true' version='1' lat='0.0' lon='3.2'>
    <tag k='name' v='source:1 == source:1:url duplicate probe' />
    <tag k='source' v='https://primary.example.com' />
    <tag k='source:1' v='https://example.org/dup' />
    <tag k='source:1:url' v='https://example.org/dup' />
    <tag k='start_date' v='1900' />
    <tag k='end_date' v='1950' />
  </node>
  <node id='9000053' visible='true' version='1' lat='0.0' lon='3.3'>
    <tag k='name' v='source:1 text source:1:url URL swap probe' />
    <tag k='source' v='https://primary.example.com' />
    <tag k='source:1' v='Local archive notes (probe)' />
    <tag k='source:1:url' v='https://example.org/url' />
