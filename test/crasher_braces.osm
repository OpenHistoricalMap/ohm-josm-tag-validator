    <tag k='end_date' v='1950' />
  </node>
  <node id='9000054' visible='true' version='1' lat='0.0' lon='3.4'>
    <tag k='name' v='source:2 and source:2:url both URLs differ probe' />
    <tag k='source' v='https://primary.example.com' />
    <tag k='source:2' v='https://example.org/two-a' />
    <tag k='source:2:url' v='https://example.org/two-b' />
    <tag k='start_date' v='1900' />
    <tag k='end_date' v='1950' />
  </node>
  <!-- Packed-date probes (start_date=YYYY-MMDD or YYYY-MDD with the
       month-day hyphen missing). Pre-v0.4.0, these flowed through the
       slash-range pipeline and produced base=0630 with a malformed
       :edtf=1930/0630, which lost the year as the base. Now handled
       as a typo-fix when year > 1200 (4-digit suffix) or > 1000
       (3-digit) AND MM-DD is a real calendar date. Bad cases (year
       > MMDD but MM-DD invalid OR year below threshold) fire 4244. -->
  <node id='9000061' visible='true' version='1' lat='0.0' lon='3.5'>
    <tag k='name' v='packed-date probe — YYYY-MMDD valid autofix' />
    <tag k='start_date' v='1875-1031' />
    <tag k='end_date' v='1900' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <node id='9000062' visible='true' version='1' lat='0.0' lon='3.6'>
    <tag k='name' v='packed-date probe — YYYY-MDD 3-digit valid autofix' />
    <tag k='start_date' v='1500-731' />
    <tag k='end_date' v='1600' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <node id='9000063' visible='true' version='1' lat='0.0' lon='3.7'>
    <tag k='name' v='packed-date probe — Feb 29 leap year valid' />
    <tag k='start_date' v='1900' />
    <tag k='end_date' v='2000-0229' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <node id='9000064' visible='true' version='1' lat='0.0' lon='3.8'>
    <tag k='name' v='packed-date probe — Nov 31 invalid 4244' />
    <tag k='start_date' v='1875-1131' />
    <tag k='end_date' v='1900' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <node id='9000065' visible='true' version='1' lat='0.0' lon='3.9'>
    <tag k='name' v='packed-date probe — year below threshold 4244' />
    <tag k='start_date' v='1100-1031' />
    <tag k='end_date' v='1200' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <node id='9000066' visible='true' version='1' lat='0.0' lon='4.0'>
    <tag k='name' v='packed-date probe — Feb 29 non-leap invalid 4244' />
    <tag k='start_date' v='1800' />
    <tag k='end_date' v='1875-0229' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <!-- Edge cases for the widened 4244 condition (initial spec only fired
       when YYYY > MMDD; widened to also fire when MM-DD is a valid
       calendar date, regardless of YYYY vs MMDD comparison). -->
  <node id='9000067' visible='true' version='1' lat='0.0' lon='4.1'>
    <!-- 4-digit edge: year < MMDD but MM-DD valid (Oct 31 of year 500).
         Pre-widening: silently fell through. Post-widening: 4244. -->
    <tag k='name' v='packed-date edge — 0500-1031 valid MD year less than MMDD' />
    <tag k='start_date' v='0500-1031' />
    <tag k='end_date' v='1600' />
    <tag k='source' v='https://example.org/source' />
  </node>
  <node id='9000068' visible='true' version='1' lat='0.0' lon='4.2'>
    <!-- 3-digit edge: year > MDD but M-DD invalid (July 32). Pre-widening:
         silently fell through (3-digit had no unfixable variant at all).
         Post-widening: 4244. -->
    <tag k='name' v='packed-date edge — 1500-732 3-digit invalid MD' />
    <tag k='start_date' v='1500-732' />
